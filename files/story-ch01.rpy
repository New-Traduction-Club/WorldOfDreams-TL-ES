    # cm "{i}I was just hoping this is some kind of bad dream.{/i}"
    cm "{i}Solo esperaba que fuera una especie de pesadilla.{/i}"

# game/story.rpy:519
translate spanish story_d29df817:

    # mc "You and me both, believe me."
    mc "Ya somos dos, créeme."

# game/story.rpy:520
translate spanish story_5de40503:

    # cm "{i}...So, can you tell me what's going on now? And who are you anyway?{/i}"
    cm "{i}... Entonces, ¿puedes decirme qué está pasando? ¿Y quién eres tú?{/i}"

# game/story.rpy:521
translate spanish story_36581b09:

    # mc "Hmm, well I'm not sure I can tell you anything about the what."
    mc "Mmm, ya, no estoy seguro de poder explicarte gran cosa sobre el qué."

# game/story.rpy:522
translate spanish story_45a9ea7e:

    # mc "And before I tell you who I am, there are a few things we should address."
    mc "Y antes de decirte quién soy, hay un par de cosas que deberíamos aclarar."

# game/story.rpy:523
translate spanish story_46838322:

    # cm "{i}Like what?{/i}"
    cm "{i}¿Como qué?{/i}"

# game/story.rpy:524
translate spanish story_fb1df181:

    # "I rub the bridge of my nose."
    "Me froto el puente de la nariz."

# game/story.rpy:525
translate spanish story_7d59d56c:

    # mc "Okay listen, what I'm about to tell you is going to make me sound crazy, so you're going to have to bear with me, alright?"
    mc "A ver, escucha, lo que voy a decirte va a sonar a locura, así que te pido que tengas un poco de paciencia conmigo, ¿vale?"

# game/story.rpy:526
translate spanish story_4f12fba3:

    # cm "{i}Well, what other choice do I have?{/i}"
    cm "{i}Bueno, ¿qué otra opción me queda?{/i}"

# game/story.rpy:527
translate spanish story_bb0eeaf4:

    # mc "Thank you."
    mc "Gracias."

# game/story.rpy:528
translate spanish story_7ad7e39c:

    # mc "First of all, I need to ask you a couple of questions. Is that okay?"
    mc "Antes de nada, tengo que hacerte un par de preguntas. ¿Te parece bien?"

# game/story.rpy:529
translate spanish story_b378e8d8:

    # cm "{i}Okay, shoot.{/i}"
    cm "{i}Venga, habla.{/i}"

# game/story.rpy:530
translate spanish story_72b9a219:

    # mc "How old are you right now?"
    mc "¿Cuántos años tienes ahora mismo?"

# game/story.rpy:531
translate spanish story_9288f4ec:

    # cm "{i}Eighteen, why?{/i}"
    cm "{i}Dieciocho, ¿por qué?{/i}"

# game/story.rpy:532
translate spanish story_17faa55f:

    # mc "I'll explain later."
    mc "Te lo explico luego."

# game/story.rpy:533
translate spanish story_a850d16b:

    # "I grab Meiji's phone and look at it. The date on the front screen reads October 22, 2017, a Sunday according to his phone."
    "Cojo el móvil de Meiji y lo miro. La fecha en la pantalla indica 22 de octubre de 2017, un domingo según el móvil."

# game/story.rpy:534
translate spanish story_20fc7e60:

    # "Okay, I admit that was not what I was expecting, but I can work with that."
    "Vale, reconozco que eso no era lo que me esperaba, pero puedo arreglármelas con eso."

# game/story.rpy:535
translate spanish story_d38f7f40:

    # "The game isn't clear on what day the MC joins the club, but it definitely wasn't a Sunday."
    "En el juego no queda claro qué día se une el protagonista al club, pero seguro que no fue un domingo."

# game/story.rpy:536
translate spanish story_b80a08b0:

    # mc "Hey, you're a third year in high school, right?"
    mc "Oye, estás en tercero de instituto, ¿verdad?"

# game/story.rpy:537
translate spanish story_652a0eea:

    # cm "{i}Yes, why?{/i}"
    cm "{i}Sí, ¿por qué?{/i}"

# game/story.rpy:538
translate spanish story_1b543e67:

    # mc "Does your school have a Culture Festival?"
    mc "¿Vuestro insti tiene un festival cultural?"

# game/story.rpy:539
translate spanish story_34a128c2:

    # cm "{i}Yeah we do. It's next week, why do you ask?{/i}"
    cm "{i}Sí que tenemos. Es la semana que viene, ¿por qué lo preguntas?{/i}"

# game/story.rpy:540
translate spanish story_e499761a:

    # "I frown."
    "Frunzo el ceño."

# game/story.rpy:541
translate spanish story_2f9edfe9:

    # mc "Only one more day until the game begins. Or two, I don't know."
    mc "Solo queda un día para que empiece el juego. O dos, no lo sé."

# game/story.rpy:542
translate spanish story_8ed28640:

    # cm "{i}Game? What game?{/i}"
    cm "{i}¿Juego? ¿Qué juego?{/i}"

# game/story.rpy:543
translate spanish story_4a0c0fd2:

    # mc "A game of life and death involving you. Well, us now, I guess."
    mc "Un juego de vida o muerte en el que estás involucrado. Bueno, en el que estamos involucrados nosotros, supongo."

# game/story.rpy:544
translate spanish story_95c3c840_2:

    # cm "..."
    cm "..."

# game/story.rpy:545
translate spanish story_14fe66fe:

    # cm "{i}What do you mean?{/i}"
    cm "{i}¿A qué te refieres?{/i}"

# game/story.rpy:546
translate spanish story_a20cefa7_1:

    # "..."
    "..."

# game/story.rpy:547
translate spanish story_99f40db0:

    # "Should I tell him, or not?"
    "¿Debería decírselo o no?"

# game/story.rpy:548
translate spanish story_0494228b:

    # "I'm not sure how he'll react to being told he's just a camera for a horror visual novel."
    "No tengo claro cómo se tomará que le diga que no es más que la cámara de una novela visual de terror."

# game/story.rpy:549
translate spanish story_1a16d48d:

    # "Ah hell, screw it!"
    "Ah... ¡A la mierda!"

# game/story.rpy:550
translate spanish story_4e26b111:

    # mc "Listen very carefully."
    mc "Escúchame muy bien."

# game/story.rpy:551
translate spanish story_68c278ee:

    # mc "What I'm about to say can never leave these lips by either of us. Got it?"
    mc "Lo que voy a contarte no puede salir jamás de nuestros labios. ¿Entendido?"

# game/story.rpy:552
translate spanish story_95c3c840_3:

    # cm "..."
    cm "..."

# game/story.rpy:553
translate spanish story_f52e09bb:

    # cm "{i}Okay, you're freaking me out a bit.{/i}"
    cm "{i}Vale, me estás asustando un poco.{/i}"

# game/story.rpy:554
translate spanish story_8f20e215:

    # mc "I'm sorry, but this is important. Please make me that promise. You cannot tell a soul, not yet anyway."
    mc "Lo siento, pero esto es importante. Por favor, prométemelo. No puedes contarle nada a nadie, al menos de momento."

# game/story.rpy:555
translate spanish story_6cb3ce8f:

    # cm "{i}Okay, I don't know how I could tell anyone, but I promise.{/i}"
    cm "{i}Vale, no sé cómo podría decírselo a alguien, pero te lo prometo.{/i}"

# game/story.rpy:556
translate spanish story_aadca25d:

    # "Here goes nothing..."
    "Ahora o nunca..."

# game/story.rpy:558
translate spanish story_7002245a:

    # mc "Alright, well the world you live in, this world, is not what you think. You know what a visual novel is, right?"
    mc "Muy bien, el mundo en el que vives, este mundo, no es lo que crees. Sabes lo que es una novela visual, ¿verdad?"

# game/story.rpy:559
translate spanish story_bd2cbdb9:

    # cm "{i}Of course I do.{/i}"
    cm "{i}Pues claro que sí.{/i}"

# game/story.rpy:560
translate spanish story_82566680:

    # mc "You're a part of a visual novel called {i}Doki Doki Literature Club{/i}. In fact, you're the main protagonist."
    mc "Eres parte de una novela visual llamada {i}Doki Doki Literature Club{/i}. De hecho, eres el protagonista principal."

# game/story.rpy:561
translate spanish story_95c3c840_4:

    # cm "..."
    cm "..."

# game/story.rpy:562
translate spanish story_550c2b97:

    # cm "{i}Don't screw with me!{/i}"
    cm "{i}¡No me fastidies!{/i}"

# game/story.rpy:563
translate spanish story_182d00d6:

    # "There it is. There's the reaction I was expecting."
    "Ahí está. Justo la reacción que me esperaba."

# game/story.rpy:564
translate spanish story_91eb36ba:

    # mc "I'm not, I promise."
    mc "No lo hago, te lo prometo."

# game/story.rpy:565
translate spanish story_5749bcf9:

    # cm "{i}Oh yeah? If that's the truth, then why me? I'm nothing special!{/i}"
    cm "{i}¿Ah, sí? Si eso es verdad, ¿entonces por qué yo? ¡No tengo nada de especial!{/i}"

# game/story.rpy:566
translate spanish story_c794ba8a:

    # mc "Exactly! The people who created the game wanted to create a person who didn't stand out much even as a background character in an anime."
    mc "¡Exacto! Los creadores del juego querían diseñar a una persona que no destacase mucho, ni siquiera como personaje de fondo en un anime."

# game/story.rpy:567
translate spanish story_3d73949e:

    # cm "{i}Oh wow, thanks for that...{/i}"
    cm "{i}Ah, genial, muchas gracias...{/i}"

# game/story.rpy:568
translate spanish story_06e7e309:

    # "I really should have phrased that better..."
    "Debería haberlo expresado de otra forma..."

# game/story.rpy:569
translate spanish story_46530b39:

    # mc "I didn't mean anything by it! It's just that the player is meant to identify with you. Normally, people who play visual novels and dating sims are nerds like you and me, right?"
    mc "¡No lo decía a malas! Es solo que se supone que el jugador debe sentirse identificado contigo. Normalmente, la gente que juega a novelas visuales y simuladores de citas son unos frikis como tú y como yo."

# game/story.rpy:570
translate spanish story_da6c8893:

    # mc "I get how this sounds, believe me, but if you want proof, I do know some things about you that I learned from playing the game before."
    mc "Ya, sé cómo suena, créeme, pero si quieres pruebas, sé algunas cosas sobre ti que aprendí al haber jugado al juego."

# game/story.rpy:571
translate spanish story_74269231:

    # "I can hear Meiji's snort of disbelief."
    "Puedo oír a Meiji resoplar con incredulidad."

# game/story.rpy:572
translate spanish story_6434f3d8:

    # cm "{i}Oh, this ought to be good. Go on then.{/i}"
    cm "{i}Ah, esto tiene que ser bueno. Venga, dime.{/i}"

# game/story.rpy:573
translate spanish story_12d30e6b:

    # "I clear my throat."
    "Me aclaro la garganta."

# game/story.rpy:574
translate spanish story_b88560de:

    # mc "You have a childhood best friend named Sayori. Short hair, red bow, bright blue eyes and always smiling and happy."
    mc "Tienes una amiga de la infancia llamada Sayori. Pelo corto, lazo rojo, ojos de un azul intenso y siempre está feliz y sonriente."

# game/story.rpy:575
translate spanish story_139a58ae:

    # mc "You're going to high school with her, but you haven't spent time with her much since high school started."
    mc "Vas al insti con ella, pero no habéis pasado mucho tiempo juntos desde que empezasteis las clases."

# game/story.rpy:576
translate spanish story_9c339ad1:

    # mc "Oh, and you also had class with a girl named Monika last year."
    mc "Ah, y el año pasado también compartiste clase con una chica llamada Monika."

# game/story.rpy:577
translate spanish story_14a02097:

    # mc "How am I doing so far?"
    mc "¿Te suena algo?"

# game/story.rpy:578
translate spanish story_05198005:

    # cm "{i}...What? How do you know about Sayori and Monika?!{/i}"
    cm "{i}¿Qué? ¡¿Cómo sabes lo de Sayori y Monika?!{/i}"

# game/story.rpy:579
translate spanish story_75b54629:

    # mc "They're both characters in the game."
    mc "Ambas son personajes del juego."

# game/story.rpy:580
translate spanish story_cf1ea9fc:

    # cm "{i}I see...{/i}"
    cm "{i}Ya...{/i}"

# game/story.rpy:581
translate spanish story_d6503474:

    # "We both go silent. I'm sure that Meiji isn't quite convinced of what I'm telling him, but I can't blame him for it."
    "Ambos nos quedamos en silencio. Seguro que a Meiji no le acaba de convencer lo que le cuento, pero no puedo culparlo."

# game/story.rpy:582
translate spanish story_79dee56d:

    # cm "{i}So what do we do now?{/i}"
    cm "{i}¿Y qué hacemos ahora?{/i}"

# game/story.rpy:583
translate spanish story_99a0d553:

    # mc "Alright. For starters, why don't we spend part of today with Sayori?"
    mc "Vale. Para empezar, ¿por qué no pasamos parte del día de hoy con Sayori?"

# game/story.rpy:584
translate spanish story_b0f69b54:

    # cm "{i}Wait, Sayori? How come?{/i}"
    cm "{i}Espera, ¿Sayori? ¿Por qué?{/i}"

# game/story.rpy:585
translate spanish story_51383c01:

    # mc "Why not? You guys are friends, right? Why wouldn't you want to spend time with her?"
    mc "¿Por qué no? Sois amigos, ¿verdad? ¿Por qué no ibas a querer pasar tiempo con ella?"

# game/story.rpy:586
translate spanish story_87ba9f60:

    # cm "{i}I...I don't know. I always thought she could do so much better than me. Like you said earlier, I'm no one special.{/i}"
    cm "{i}Yo... no lo sé. Siempre he pensado que ella podía aspirar a mucho más que yo. Como dijiste antes, no soy nadie especial.{/i}"

# game/story.rpy:587
translate spanish story_e207540d:

    # cm "{i}She's pretty well known at school and I'm sure some of her classmates even have a crush on her.{/i}"
    cm "{i}Es bastante popular en el instituto y estoy seguro de que hasta le gusta a algunos de sus compañeros.{/i}"

# game/story.rpy:588
translate spanish story_9bde94e2:

    # "Whoa."
    "Guau."

# game/story.rpy:589
translate spanish story_078566e7:

    # "Not what I was expecting. I assumed that the protagonist stopped hanging out with Sayori because of him being so generic, but the truth is a lot more realistic."
    "No me esperaba esto. Creía que el protagonista había dejado de quedar con Sayori por ser demasiado genérico, pero la verdad es mucho más realista."

# game/story.rpy:590
translate spanish story_ca959185:

    # "And a little bit depressing, to be honest. Oh boy, is this Meiji gonna have a meltdown?"
    "Y un poco deprimente, para qué engañarnos. Madre mía, ¿le va a dar a Meiji un ataque de nervios?"

# game/story.rpy:591
translate spanish story_12fa6dc3:

    # "He's not a bad person, per se, but he might start feeling guilty about things."
    "No es mala persona, de por sí, pero puede que empiece a sentirse culpable por ciertas cosas."

# game/story.rpy:592
translate spanish story_60d0818b:

    # "I try my best to reassure him."
    "Hago lo que puedo para tranquilizarlo."

# game/story.rpy:593
translate spanish story_4a0965bd:

    # mc "Do you really think that? If she really thought that, would she have even played with you when you two were kids?"
    mc "¿De verdad piensas eso? Si pensase así, ¿crees que habría jugado contigo cuando erais pequeños?"

# game/story.rpy:594
translate spanish story_5709f43c:

    # mc "Didn't you help whenever she hurt herself? What about when she nearly burned her house down when she tried cooking?"
    mc "¿Acaso no la ayudabas siempre que se hacía daño? ¿O cuando casi incendia su casa al intentar cocinar?"

# game/story.rpy:595
translate spanish story_c643c6e6:

    # cm "{i}How do you know about that?{/i}"
    cm "{i}¿Cómo sabes eso?{/i}"

# game/story.rpy:596
translate spanish story_09a5aa75:

    # mc "It came up in the game."
    mc "Salió en el juego."

# game/story.rpy:597
translate spanish story_8d619247:

    # "I see something on the desk. Standing I walk over and see a picture with a young Meiji and a very cute girl with a red bow and long hair."
    "Veo algo en el escritorio. Me levanto, me acerco y veo una foto de un joven Meiji y una niña muy cuqui con un lazo rojo y el pelo largo."

# game/story.rpy:598
translate spanish story_a47b895d:

    # "Unlike her sprite, this image of Sayori shows her with brown hair instead of the pink hue seen in the game."
    "A diferencia de su sprite, en esta imagen Sayori tiene el pelo castaño en lugar del tono rosado que se ve en el juego."

# game/story.rpy:599
translate spanish story_e3403ad1:

    # mc "Wow, I didn't realize Sayori had long hair at one time. She looks so cute!"
    mc "Guau, no sabía que Sayori hubiese tenido el pelo largo en el pasado. ¡Sale supercuqui!"

# game/story.rpy:600
translate spanish story_8622b59d:

    # cm "{i}She cut it a little while ago; wanted to go for a new look, I guess.{/i}"
    cm "{i}Se lo cortó hace poco. Supongo que quería probar un nuevo estilo.{/i}"

# game/story.rpy:601
translate spanish story_0cfd2061:

    # mc "Huh, okay that makes sense."
    mc "Anda. Vale, tiene sentido."

# game/story.rpy:602
translate spanish story_09cf735d:

    # "I put the picture down and sit back on the bed."
    "Dejo la foto y vuelvo a sentarme en la cama."

# game/story.rpy:603
translate spanish story_2dadd204:

    # mc "So should I continue? About the game I mean?"
    mc "Entonces, ¿continúo? Con lo del juego, me refiero."

# game/story.rpy:604
translate spanish story_d8f20007:

    # cm "{i}...Yes...{/i}"
    cm "{i}Venga.{/i}"

# game/story.rpy:605
translate spanish story_858f087b:

    # "Slowly, I explain the plot of the original game as carefully as I can."
    "Poco a poco, le explico la trama del juego original con el mayor tacto posible."

# game/story.rpy:606
translate spanish story_4b8e00d1:

    # "As I do, Meiji listens quietly, not saying a word. Sometimes I stop in my explanation to make sure he's still listening."
    "Mientras lo hago, Meiji escucha en silencio, sin decir ni una palabra. A veces, detengo mi explicación para asegurarme de que me sigue prestando atención."

# game/story.rpy:607
translate spanish story_14f4cb76:

    # "After I'm finished explaining, I wait to hear Meiji's response."
    "Cuando termino de explicarle todo, espero a escuchar la respuesta de Meiji."

# game/story.rpy:608
translate spanish story_6cfc2e74:

    # "Meiji doesn't speak for a while. I feel guilty again, but this time I have no words. I don't even know where to start. But he needs to know all this."
    "Meiji se queda callado un buen rato. Vuelvo a sentirme culpable, pero esta vez me he quedado sin palabras. No sé ni por dónde empezar. Pero tiene que saber todo esto."

# game/story.rpy:609
translate spanish story_cacfe05c:

    # "Ugh, I suck when it comes to people sometimes. I try to think of something to say to reassure him again."
    "Uf, a veces soy un desastre para tratar con la gente. Intento pensar en algo que decirle para tranquilizarlo un poco."

# game/story.rpy:610
translate spanish story_98eec459:

    # "He's probably thinking that Sayori's depression is his fault, but it isn't."
    "Probablemente piense que la depresión de Sayori es culpa suya, pero no es así."

# game/story.rpy:611
translate spanish story_0590989d:

    # "I need his help, after all. I know nothing about this world other than the names of the girls and a few background images."
    "Aun así, necesito su ayuda. No sé nada de este mundo aparte de los nombres de las chicas y un par de imágenes de fondo."

# game/story.rpy:612
translate spanish story_22b31946:

    # "This world feels more like DDLC and the real world were mashed together."
    "Este mundo da la sensación de ser una mezcla entre DDLC y el mundo real."

# game/story.rpy:613
translate spanish story_c549bb29:

    # "That begs the question, where am I? Is this really DDLC? I mean, if it were, would Sayori have that brown hair?"
    "Lo que nos lleva a la gran pregunta: ¿dónde estoy? ¿Esto es DDLC de verdad? Quiero decir, si lo fuera, ¿tendría Sayori el pelo castaño?"

# game/story.rpy:614
translate spanish story_032a3df4:

    # "Well, I think I can theorize later."
    "Bueno, ya teorizaré sobre eso más tarde."

# game/story.rpy:615
translate spanish story_69704ed0:

    # "There's only silence between us for a while."
    "Nos quedamos un rato en silencio."

# game/story.rpy:616
translate spanish story_a20cefa7_2:

    # "..."
    "..."

# game/story.rpy:617
translate spanish story_1f42c554:

    # cm "{i}A-Are you sure? Is what you said real?{/i}"
    cm "{i}¿E-Estás seguro? ¿Es verdad todo lo que has dicho?{/i}"

# game/story.rpy:618
translate spanish story_b4b5840f:

    # "Meiji's voice sounds shaky, almost as if he's in shock."
    "A Meiji le tiembla la voz, como si estuviera en estado de shock."

# game/story.rpy:619
translate spanish story_ce086c24:

    # "Damn it..."
    "Joder..."

# game/story.rpy:620
translate spanish story_b17b8914:

    # mc "Meiji?"
    mc "¿Meiji?"

# game/story.rpy:621
translate spanish story_e2073d23:

    # cm "{i}Am I not real?{/i}"
    cm "{i}¿No soy real?{/i}"

# game/story.rpy:622
translate spanish story_279afa36:

    # "Aaand he's having a nervous breakdown. Way to go, [fname]! You really screwed the pooch on this one!"
    "Yyy está sufriendo una crisis nerviosa. ¡Muy bien, [fname]! ¡Esta vez sí que la has cagado a base de bien!"

# game/story.rpy:623
translate spanish story_fa8c20fd:

    # mc "Yes, yes you are real. And you're going to help me."
    mc "Sí, sí que eres real. Y vas a ayudarme."

# game/story.rpy:624
translate spanish story_4fb2173f:

    # cm "{i}Help? How?{/i}"
    cm "{i}¿Ayudarte? ¿Cómo?{/i}"

# game/story.rpy:625
translate spanish story_357c23c4:

    # "It's time to be a fucking hero!"
    "¡Es hora de ser un puto héroe!"

# game/story.rpy:626
translate spanish story_69adeb72:

    # mc "You and I, we're going to make sure nothing happens to the girls or anyone else."
    mc "Tú y yo nos aseguraremos de que no les pase nada a las chicas ni a nadie más."

# game/story.rpy:627
translate spanish story_6f5908b2:

    # cm "{i}But how? If what you're saying is true, won't we be fighting a losing battle?{/i}"
    cm "{i}Pero, ¿cómo? Si lo que dices es cierto, ¿no será una batalla perdida?{/i}"

# game/story.rpy:628
translate spanish story_5971623e:

    # mc "I don't believe in no-win scenarios. Also, I'm a stubborn idiot."
    mc "No creo en las batallas perdidas. Te digo que soy un idiota muy testarudo."

# game/story.rpy:629
translate spanish story_b000130d:

    # "To my surprise and relief, I hear Meiji chuckle a bit."
    "Para mi sorpresa y alivio, escucho a Meiji soltar una risilla."

# game/story.rpy:630
translate spanish story_c08952cc:

    # cm "{i}Alright then, genius. What's your master plan?{/i}"
    cm "{i}Muy bien, genio. ¿Cuál es tu plan maestro?{/i}"

# game/story.rpy:631
translate spanish story_a2d3e19e:

    # mc "Hmm...nothing definite yet."
    mc "Mmm... Aún no tengo nada claro."

# game/story.rpy:632
translate spanish story_f35da993:

    # mc "For now though, we should spend today with Sayori. I'm sure she'll love it. We'll get in touch with her later."
    mc "Pero, por ahora, deberíamos pasar el día con Sayori. Seguro que le encantará. Ya nos pondremos en contacto con ella."

# game/story.rpy:633
translate spanish story_2858186d:

    # mc "In the meantime, let's get a bit more sleep."
    mc "Mientras tanto, durmamos un poco más."

# game/story.rpy:634
translate spanish story_74d93617:

    # mc "I don't mind sleeping in, but we shouldn't sleep in too long. After all, a day with Sayori is always an adventure, right?"
    mc "No me importa dormir hasta tarde, pero tampoco deberíamos pasarnos. Después de todo, un día con Sayori siempre es una aventura, ¿verdad?"

# game/story.rpy:635
translate spanish story_ff912255:

    # "I hear another small chuckle from Meiji."
    "Escucho otra risilla de Meiji."

# game/story.rpy:636
translate spanish story_6151b547:

    # cm "{i}Yes, it always is. Alright, we spend some time today with Sayori.{/i}"
    cm "{i}Sí, siempre lo es. Vale, hoy pasaremos el día con Sayori.{/i}"

# game/story.rpy:637
translate spanish story_71b90cd7:

    # mc "Let me take the reins for today. I know what's coming, you don't."
    mc "Déjame tomar las riendas por hoy. Yo sé lo que se avecina y tú no."

# game/story.rpy:638
translate spanish story_03d91d23:

    # cm "{i}I don't exactly like the idea, but we don't have a choice, I guess. Well, goodnight.{/i}"
    cm "{i}No me hace mucha gracia la idea, pero supongo que no nos queda otra. En fin, buenas noches.{/i}"

# game/story.rpy:639
translate spanish story_b9b55962:

    # "And just like that, Meiji falls asleep."
    "Y, así sin más, Meiji se queda dormido."

# game/story.rpy:640
translate spanish story_6c3a4f67:

    # "Not sure how I know. It's like a pressure in my head vanishes."
    "No sé cómo lo sé. Es como si una presión en mi cabeza se hubiera desvanecido."

# game/story.rpy:646
translate spanish story_4db8ef55:

    # "I lie back down but can't sleep."
    "Vuelvo a tumbarme, pero no logro conciliar el sueño."

# game/story.rpy:647
translate spanish story_a057449a:

    # "My mind is racing a mile a minute."
    "Mi cabeza va a mil por hora."

# game/story.rpy:648
translate spanish story_781c6eba:

    # mc "How do I do this?"
    mc "¿Cómo lo hago?"

# game/story.rpy:649
translate spanish story_3f024f5f:

    # "The tension from before begins to come back again."
    "La tensión de antes empieza a apoderarse de mí otra vez."

# game/story.rpy:650
translate spanish story_d3c181d2:

    # "From the door I begin hearing movement. The door opens and someone peers in."
    "Empiezo a escuchar movimiento cerca de la puerta. Se abre y alguien asoma la cabeza."

# game/story.rpy:651
translate spanish story_50550a14:

    # "I pretend to be asleep, not wanting to worry Meiji's parents any more."
    "Finjo estar dormido para no preocupar más a los padres de Meiji."

# game/story.rpy:652
translate spanish story_4eeb9a1b:

    # "After a little while the door closes."
    "Poco después, la puerta se cierra."

# game/story.rpy:653
translate spanish story_56970b50:

    # "I try to relax, but still can't sleep. Various scenarios play in my head."
    "Intento relajarme, pero sigo sin poder dormir. Por mi cabeza pasan todo tipo de situaciones."

# game/story.rpy:654
translate spanish story_c33035ea:

    # "What do I do?"
    "¿Qué hago?"

# game/story.rpy:655
translate spanish story_243d06f4:

    # "Should I confront Monika?"
    "¿Debería plantarle cara a Monika?"

# game/story.rpy:656
translate spanish story_d470a68f:

    # "Should I even join the damn club?"
    "¿Debería siquiera unirme al dichoso club?"

# game/story.rpy:657
translate spanish story_92f32744:

    # "If I don't join the club, will Monika even get her epiphany?"
    "Si no me uno, ¿llegará Monika a tener su epifanía?"

# game/story.rpy:658
translate spanish story_3338c0a3:

    # "Or will something else cause Sayori to hang herself again?"
    "¿O habrá otra cosa que provoque que Sayori vuelva a ahorcarse?"

# game/story.rpy:659
translate spanish story_1676541b:

    # mc "Gah! Enough of this!"
    mc "¡Joder! ¡Ya basta de darle vueltas!"

# game/story.rpy:660
translate spanish story_02e108dd:

    # "I stand and head to the door, switching on the light."
    "Me levanto, me acerco a la puerta y enciendo la luz."

# game/story.rpy:665
translate spanish story_9f7bd6d3:

    # "I blink and eventually my eyes adjust."
    "Pestañeo y, al cabo de un rato, mis ojos se acostumbran a la claridad."

# game/story.rpy:666
translate spanish story_ed315e36:

    # "In a corner of the room not usually seen, I spot something."
    "En un rincón de la habitación que suele pasar desapercibido, veo algo."

# game/story.rpy:667
translate spanish story_a2791611:

    # "It's my backpack!"
    "¡Es mi mochila!"

# game/story.rpy:668
translate spanish story_1a47f4c7:

    # "My own backpack from reality."
    "Mi propia mochila del mundo real."

# game/story.rpy:669
translate spanish story_702cc98b:

    # "Not sure how it got here, but I'm glad it is."
    "No sé cómo ha llegado hasta aquí, pero me alegro de que lo haya hecho."

# game/story.rpy:670
translate spanish story_95daf10e:

    # "I head over and unzip it."
    "Me acerco y le abro la cremallera."

# game/story.rpy:671
translate spanish story_baaba165:

    # mc "Jackpot!"
    mc "¡Bingo!"

# game/story.rpy:672
translate spanish story_8a006995:

    # "I grin as I see my laptop, phone and headphones as well as a small Bluetooth speaker."
    "Sonrío de oreja a oreja al ver mi portátil, mi móvil y mis auriculares, además de un pequeño altavoz Bluetooth."

# game/story.rpy:673
translate spanish story_4fc5a24f:

    # "I also find the chargers for my laptop and phone in the other pouch."
    "También encuentro los cargadores en el otro bolsillo."

# game/story.rpy:674
translate spanish story_7d4b5633:

    # "I chuckle as I see a few pens in a smaller pouch on the front."
    "Suelto una risita al encontrar unos cuantos bolígrafos en un bolsillo más pequeño de la parte delantera."

# game/story.rpy:675
translate spanish story_a86d3566:

    # "I turn my phone on and attempt to access the internet."
    "Enciendo el móvil e intento conectarme a internet."

# game/story.rpy:676
translate spanish story_9850f53c:

    # "Nothing."
    "Nada."

# game/story.rpy:677
translate spanish story_1d564d41:

    # "I try on another app, still nothing."
    "Pruebo con otra aplicación y sigue sin funcionar."

# game/story.rpy:678
translate spanish story_033a1277:

    # mc "Guess I can't access the internet...unless there's WiFi here."
    mc "Supongo que no puedo acceder a internet... a no ser que aquí haya wifi."

# game/story.rpy:679
translate spanish story_0da3b8e8:

    # "I check the WiFi and find a few, but they're all locked."
    "Busco redes wifi y encuentro unas cuantas, pero todas tienen contraseña."

# game/story.rpy:680
translate spanish story_f7f31383:

    # "Eh, I'll ask for the password later."
    "Ya pediré la contraseña luego."

# game/story.rpy:681
translate spanish story_44af8e7b:

    # "I plug my phone and laptop in, hoping they'll charge."
    "Enchufo el móvil y el portátil con la esperanza de que carguen."

# game/story.rpy:682
translate spanish story_36f6f609:

    # "Thank God, they do."
    "Gracias a Dios, sí."

# game/story.rpy:683
translate spanish story_b5721708:

    # "Not wanting any of this to be discovered, I hide my backpack in the back of Meiji's closet and put the laptop under the desk."
    "Como no quiero que nadie lo descubra, escondo mi mochila en el fondo del armario de Meiji y pongo el portátil debajo del escritorio."

# game/story.rpy:684
translate spanish story_6757ffdb:

    # "I then turn off the light."
    "Luego apago la luz."

# game/story.rpy:689
translate spanish story_30f83210:

    # "As I lay there, I ponder over the choices I have before me once more."
    "Mientras estoy ahí tumbado, le doy vueltas de nuevo a las opciones que tengo ante mí."

# game/story.rpy:690
translate spanish story_fea90392:

    # "I have a day or two to prepare for the upcoming encounter with the girls and I still don't quite know how to approach it."
    "Tengo un día o dos para prepararme para el próximo encuentro con las chicas y aún no sé muy bien cómo abordarlo."

# game/story.rpy:691
translate spanish story_5003b811:

    # "As I go over the ideas, a new one strikes me."
    "Mientras repaso las ideas, se me ocurre una nueva."

# game/story.rpy:692
translate spanish story_dfa07c95:

    # "I grab my phone, put a note in a notepad app then lay back down."
    "Cojo el móvil, apunto una nota en la aplicación de notas y me vuelvo a tumbar."

# game/story.rpy:693
translate spanish story_36c6ae00:

    # mc "I'll run it by Meiji tomorrow."
    mc "Se lo comentaré a Meiji mañana."

# game/story.rpy:694
translate spanish story_ca08ca28:

    # "Eventually, I fall asleep."
    "Al final, me quedo dormido."

# game/story.rpy:702
translate spanish story_5b960979:

    # "I wake to sunlight coming in from the window."
    "Me despierto con la luz del sol que entra por la ventana."

# game/story.rpy:703
translate spanish story_b46c2c97:

    # "I sit up slowly, yawn and stretch before pulling back the curtains."
    "Me siento despacio, bostezo y me estiro antes de descorrer las cortinas."

# game/story.rpy:708
translate spanish story_8888c0e3:

    # cm "{i}Hey, you. You're finally awake.{/i}"
    cm "{i}Oye, tú. Por fin has despertado.{/i}"

# game/story.rpy:709
translate spanish story_00b2bbbe:

    # "Meiji sounds exasperated."
    "Meiji suena exasperado."

# game/story.rpy:710
translate spanish story_9ef2c589:

    # "I decide to try and lighten the mood with a bit of humor."
    "Decido intentar animar el ambiente con un poco de humor."

# game/story.rpy:711
translate spanish story_70c46511:

    # mc "Walked right into that Imperial ambush while I was trying to cross the border."
    mc "Fui a caer en la emboscada de los imperiales mientras intentaba cruzar la frontera."

# game/story.rpy:712
translate spanish story_8d579d90:

    # "I chuckle, throw the blankets off of me and swing my legs over the bed."
    "Suelto una risita, me quito las mantas de encima y dejo caer las piernas por el borde de la cama."

# game/story.rpy:713
translate spanish story_7e44673f:

    # mc "How long have you been awake?"
    mc "¿Cuánto tiempo llevas despierto?"

# game/story.rpy:714
translate spanish story_83fee47c:

    # cm "{i}Not long, but I still couldn't take control even when you were asleep.{/i}"
    cm "{i}No mucho, pero no pude tomar el control ni siquiera mientras dormías.{/i}"

# game/story.rpy:715
translate spanish story_8626f67e:

    # mc "Really? That's odd."
    mc "¿En serio? Qué raro."

# game/story.rpy:716
translate spanish story_cc51c67c:

    # "The clock on Meiji's phone reads 9:38 AM."
    "El reloj del móvil de Meiji marca las 9:38 de la mañana."

# game/story.rpy:717
translate spanish story_ae5ae567:

    # mc "Not too early but not too late either, good. Gives us time to shower and eat breakfast. Well, why don't we get ready for a day of fun before school tomorrow?"
    mc "Ni muy pronto ni muy tarde, genial. Nos da tiempo a ducharnos y desayunar. Bueno, ¿por qué no nos preparamos para un día de diversión antes de ir a clase mañana?"

# game/story.rpy:718
translate spanish story_5d804af9:

    # cm "{i}Yeah…I guess…{/i}"
    cm "{i}Sí... Supongo...{/i}"

# game/story.rpy:719
translate spanish story_adbe6ab1:

    # "I sense a reluctance in his tone."
    "Noto cierta reticencia en su tono."

# game/story.rpy:720
translate spanish story_32fda9be:

    # mc "Meiji? You okay?"
    mc "¿Meiji? ¿Estás bien?"

# game/story.rpy:721
translate spanish story_c4de3e2d:

    # cm "{i}It's just...I still feel bad about leaving Sayori alone for so many years. For drifting apart...for causing her depression...{/i}"
    cm "{i}Es solo que... me sigo sintiendo mal por haber dejado sola a Sayori tantos años. Por habernos distanciado... Por causarle la depresión...{/i}"

# game/story.rpy:722
translate spanish story_2b3dd59c:

    # mc "You didn't cause her depression. Depression is a medical issue caused by a chemical imbalance in the brain."
    mc "Tú no causaste su depresión. La depresión es un problema médico provocado por un desequilibrio químico en el cerebro."

# game/story.rpy:723
translate spanish story_85b509a0:

    # mc "Besides, today is the day we can start amending for it."
    mc "Además, hoy es el día en que podemos empezar a compensarla."

# game/story.rpy:724
translate spanish story_a0b7f8f9:

    # mc "I may be the one in control, but I want to help the two of you get closer again."
    mc "Puede que yo tenga el control, pero quiero ayudaros a que volváis a uniros."

# game/story.rpy:725
translate spanish story_ccc58dbb:

    # mc "It's the least I can do in our current situation."
    mc "Es lo mínimo que puedo hacer en nuestra situación actual."

# game/story.rpy:726
translate spanish story_12d30e6b_1:

    # "I clear my throat."
    "Me aclaro la garganta."

# game/story.rpy:727
translate spanish story_cd1acdbd:

    # mc "Also, I had an idea after you went to sleep last night…about one way to save the girls."
    mc "Además, se me ocurrió una idea después de que te durmieras anoche... sobre una forma de salvar a las chicas."

# game/story.rpy:728
translate spanish story_e83964f8:

    # cm "...{i}Am I gonna like this idea?{/i}"
    cm "... {i}¿Me va a gustar esa idea?{/i}"

# game/story.rpy:729
translate spanish story_824a2b00:

    # mc "Probably not, but I want to run it by you anyway. We should let Sayori know about...me."
    mc "Puede que no, pero quiero comentártela de todos modos. Deberíamos contarle a Sayori lo de... mi existencia."

# game/story.rpy:730
translate spanish story_3301b68f:

    # cm "{i}Wait, first you tell me not to tell anyone, now you want me to?!{/i}"
    cm "{i}Un momento, ¡¿primero me dices que no se lo cuente a nadie y ahora quieres que lo haga?!{/i}"

# game/story.rpy:731
translate spanish story_421204a3:

    # mc "Yeah, I know what I said last night, but-"
    mc "Sí, ya sé lo que dije anoche, pero..."

# game/story.rpy:732
translate spanish story_b8ed5c28:

    # cm "{i}That's insane! She'll never believe it! She'll think I'm just playing a trick on her like-{/i}"
    cm "{i}¡Es una locura! ¡Nunca se lo creerá! Pensará que le estoy gastando una broma como...{/i}"

# game/story.rpy:733
translate spanish story_330ad9e2:

    # "He stops suddenly."
    "Se calla de repente."

# game/story.rpy:734
translate spanish story_3fa76d87:

    # mc "Like how you have in the past, right?"
    mc "Como has hecho en el pasado, ¿verdad?"

# game/story.rpy:735
translate spanish story_a3a39b46:

    # "Despite how he's portrayed in the game, I don't think Meiji's a bad guy. Maybe a bit insensitive, but not all that is his fault."
    "A pesar de cómo lo retratan en el juego, no creo que Meiji sea un mal tipo. Quizá sea un poco insensible, pero no toda la culpa es suya."

# game/story.rpy:736
translate spanish story_4a78dcad:

    # mc "Meiji, I'm not saying we tell her about everything. I'm just saying that we tell her that I'm another personality that emerged recently or something."
    mc "Meiji, no digo que se lo contemos todo. Solo digo que le expliquemos que soy otra personalidad que ha surgido hace poco o algo así."

# game/story.rpy:737
translate spanish story_2d5b531b:

    # mc "I tell her I have memories of a life I've never really lived and that I woke up in your body."
    mc "Le diré que tengo recuerdos de una vida que nunca he vivido realmente y que me he despertado en tu cuerpo."

# game/story.rpy:738
translate spanish story_b9f3ac18:

    # mc "I say you and I can communicate with each other and that we're working on a way to let you take control again."
    mc "Diré que tú y yo podemos comunicarnos y que estamos buscando la forma de que vuelvas a tomar el control."

# game/story.rpy:739
translate spanish story_408ee5a2:

    # cm "{i}And her club?{/i}"
    cm "{i}¿Y qué hay de su club?{/i}"

# game/story.rpy:740
translate spanish story_d0593536:

    # "I pause. I hadn't thought it through completely the night before. Another scenario plays out in my head."
    "Hago una pausa. No lo había pensado a fondo la noche anterior. Otro escenario se desarrolla en mi cabeza."

# game/story.rpy:741
translate spanish story_f700b367:

    # "What if Sayori doesn't invite Meiji to the club after I tell her what was going on today?"
    "¿Y si Sayori no invita a Meiji al club después de que le cuente lo que ha pasado hoy?"

# game/story.rpy:742
translate spanish story_286f9418:

    # mc "You have a point. How annoying. Sayori might not take us to the club that day."
    mc "Tienes razón. Qué fastidio. Puede que Sayori no nos lleve al club ese día."

# game/story.rpy:743
translate spanish story_4677075d:

    # mc "I still think telling her is a good idea. Maybe instead of telling her alone, we tell them all at once."
    mc "Aun así, creo que contárselo es buena idea. Quizá, en lugar de decírselo a ella a solas, se lo digamos a todas a la vez."

# game/story.rpy:744
translate spanish story_d0425bf3:

    # mc "Maybe the other members of her club can help too."
    mc "A lo mejor las otras chicas del club también pueden ayudar."

# game/story.rpy:745
translate spanish story_398f1e7e:

    # mc "Yuri may know of some way to let you come through. And we're going to need Monika's help too."
    mc "Es posible que Yuri conozca alguna forma de dejarte salir. Y también necesitaremos la ayuda de Monika."

# game/story.rpy:746
translate spanish story_b67ffce3:

    # cm "{i}That…makes a bit more sense. So, are you going to act like me today?{/i}"
    cm "{i}Ya, tiene sentido. Entonces, ¿vas a actuar como si fueras yo hoy?{/i}"

# game/story.rpy:747
translate spanish story_d939b9c2:

    # mc "I'll do my best. I hate doing it, but it's for the best."
    mc "Haré lo que pueda. Odio hacerlo, pero es lo mejor."

# game/story.rpy:748
translate spanish story_322db544:

    # mc "But if you don't think we should do that we can just stay home and experiment or just relax. This is your body, after all."
    mc "Pero si crees que no deberíamos hacerlo, podemos quedarnos en casa y hacer pruebas o simplemente relajarnos. Al fin y al cabo es tu cuerpo."

# game/story.rpy:749
translate spanish story_95c3c840_5:

    # cm "..."
    cm "..."

# game/story.rpy:750
translate spanish story_19f31241:

    # cm "{i}I think what you say makes sense. You can act like me today. But I have the right to change my mind, okay?{/i}"
    cm "{i}Creo que tiene sentido. Puedes actuar como yo hoy. Pero tengo derecho a cambiar de opinión, ¿vale?{/i}"

# game/story.rpy:751
translate spanish story_64987cae:

    # mc "I've no problem with that. I {i}would{/i} say shake on it, but that'd be redundant."
    mc "Vale, sin problema. Te diría que nos diéramos la mano, pero sería redundante."

# game/story.rpy:752
translate spanish story_ea5bc60d:

    # cm "{i}Har har.{/i}"
    cm "{i}Ja, ja, muy gracioso.{/i}"

# game/story.rpy:753
translate spanish story_36aff988:

    # mc "Oh, I'm a funny guy. Alright, let's text Sayori and ask if she wants to hang with us today, but first…Meiji, where's your wallet?"
    mc "Ya ves, soy un tipo muy gracioso. Muy bien, enviémosle un mensaje a Sayori y preguntémosle si quiere salir a pasar el rato con nosotros hoy, pero primero... Meiji, ¿dónde está tu cartera?"

# game/story.rpy:754
translate spanish story_bb1ea02d:

    # cm "{i}On my desk.{/i}"
    cm "{i}En mi escritorio.{/i}"

# game/story.rpy:755
translate spanish story_a865670f:

    # "I spot a small brown wallet. I open it and count out the bills."
    "Veo una pequeña cartera marrón. La abro y cuento los billetes."

# game/story.rpy:756
translate spanish story_0d8d4bd9:

    # mc "Geez, how rich are your parents to be able to afford giving all this money?"
    mc "Madre mía, ¿cómo de ricos son tus padres para poder permitirse darte todo este dinero?"

# game/story.rpy:757
translate spanish story_2d1a9cc4:

    # cm "{i}It's a part of my allowance. I don't really go out much so I've been saving it.{/i}"
    cm "{i}Es parte de mi paga. No salgo mucho, así que lo he estado ahorrando.{/i}"

# game/story.rpy:758
translate spanish story_5295cac6:

    # mc "For what, a car?"
    mc "¿Para qué? ¿Para un coche?"

# game/story.rpy:759
translate spanish story_fb5e6cac:

    # cm "{i}Nothing in particular. I'm not very social.{/i}"
    cm "{i}Para nada en particular. No soy muy sociable.{/i}"

# game/story.rpy:760
translate spanish story_41d035a1:

    # mc "I get that, I'm the same."
    mc "Te entiendo, yo soy igual."

# game/story.rpy:761
translate spanish story_8a43c21e:

    # "I grab a pair of jeans and a black T-shirt with a hoodie to match."
    "Cojo unos vaqueros y una camiseta negra con una sudadera a juego."

# game/story.rpy:762
translate spanish story_cb76b975:

    # mc "Alright, now let's text Sayori. I'm gonna need your help too. I don't know the layout of your city. What is your city's name, anyway?"
    mc "Vale, ahora escribamos a Sayori. También voy a necesitar tu ayuda. No conozco el plano de tu ciudad. ¿Cómo se llama tu ciudad, por cierto?"

# game/story.rpy:763
translate spanish story_5712ebfd:

    # cm "{i}I've been relegated to internal GPS. And it's Kōzai.{/i}"
    cm "{i}Me han relegado a la función de GPS interno. Kōzai es la ciudad.{/i}"

# game/story.rpy:764
translate spanish story_22bf2f10:

    # mc "Oh stop. If I knew how to let you take control, I'd give it back. And Kōzai huh? Good to know. What's the name of the school?"
    mc "Basta. Si supiera cómo devolverte el control, lo haría. Conque Kōzai, ¿eh? ¿Cómo se llama el instituto?"

# game/story.rpy:765
translate spanish story_90c5f962:

    # cm "{i}Sakura Academy.{/i}"
    cm "{i}Sakura Academy.{/i}"

# game/story.rpy:766
translate spanish story_6eb61bef:

    # "Of course it is."
    "Pues claro."

# game/story.rpy:767
translate spanish story_1c57328c:

    # "I look through Meiji's contacts and find his parents, Sayori and someone named Aiko."
    "Busco en los contactos de Meiji y encuentro a sus padres, a Sayori y a una tal Aiko."

# game/story.rpy:768
translate spanish story_53ad33b3:

    # mc "Who's Aiko?"
    mc "¿Quién es Aiko?"

# game/story.rpy:769
translate spanish story_01e1a5f1:

    # cm "{i}My older sister. She's away at college right now.{/i}"
    cm "{i}Mi hermana mayor. Ahora mismo está en la universidad.{/i}"

# game/story.rpy:770
translate spanish story_e5789ec4:

    # "Okay...that was definitely something not mentioned in the game. I wonder if that was her room across the hall."
    "Vale... eso definitivamente no se mencionaba en el juego. Me pregunto si la habitación al otro lado del pasillo era la suya."

# game/story.rpy:771
translate spanish story_a2171afe:

    # mc "Wow, I didn't realize you had an older sister."
    mc "Hala, no sabía que tenías una hermana mayor."

# game/story.rpy:772
translate spanish story_76f90a5d:

    # "I decide to tease him in an attempt to help him relax a bit, as well as get a little bit of revenge for all the times he teased Sayori."
    "Decido chincharle un poco para ayudarle a relajarse, y también como pequeña venganza por todas las veces que él se ha metido con Sayori."

# game/story.rpy:773
translate spanish story_5e3acbbc:

    # mc "Is she hot?"
    mc "¿Está buena?"

# game/story.rpy:774
translate spanish story_7416702d:

    # cm "{i}Hey!{/i}"
    cm "{i}¡Oye!{/i}"

# game/story.rpy:775
translate spanish story_c67aa92c:

    # mc "I'm kidding, I'm kidding!"
    mc "¡Es broma, es broma!"

# game/story.rpy:776
translate spanish story_5f7aa012:

    # mc "...but is she?"
    mc "Pero, ¿lo está?"

# game/story.rpy:777
translate spanish story_8cf0c516:

    # "I snicker a bit."
    "Suelto una risita."

# game/story.rpy:778
translate spanish story_d37fa2c3:

    # cm "{i}Cut it out!{/i}"
    cm "{i}¡Para ya!{/i}"

# game/story.rpy:779
translate spanish story_ac831076:

    # mc "Alright, alright. Does she live on campus?"
    mc "Vale, vale. ¿Vive en el campus?"

# game/story.rpy:780
translate spanish story_dc154510:

    # cm "{i}Yes.{/i}"
    cm "{i}Sí.{/i}"

# game/story.rpy:781
translate spanish story_26ef52f3:

    # "He sounds grumpy as he says that."
    "Suena gruñón al decir eso."

# game/story.rpy:782
translate spanish story_b54d8537:

    # cm "{i}Sorry if that bursts your bubble.{/i}"
    cm "{i}Siento chafarte la ilusión.{/i}"

# game/story.rpy:783
translate spanish story_42db48bd:

    # mc "Come on, don't be mad, I won't do anything like pursue your hot sister. Alright, here we go."
    mc "Venga, no te enfades, no voy a ir detrás de tu atractiva hermana ni nada de eso."

# game/story.rpy:784
translate spanish story_fc28aa20:

    # "I take out Meiji's phone and shoot a text off to Sayori."
    "Saco el móvil de Meiji y le envío un mensaje a Sayori."

# game/story.rpy:785
translate spanish story_5ccc31ae:

    # mc "{i}{u}Sayori! Hey, it's Meiji. Wanna go and have some fun today?{/i}{/u}"
    mc "{i}{u}¡Sayori! Hola, soy Meiji. ¿Te apetece que salgamos a divertirnos hoy?{/i}{/u}"

# game/story.rpy:786
translate spanish story_606c1c10:

    # "It takes me a while because I'm not used to sending a text using a flip phone keypad."
    "Tardo un rato porque no estoy acostumbrado a mandar mensajes con el teclado de un móvil de tapa."

# game/story.rpy:787
translate spanish story_a5a7d3e2:

    # mc "Now we play the waiting game."
    mc "Ahora toca esperar."

# game/story.rpy:788
translate spanish story_d5bec6b0:

    # "A few moments later a reply comes through."
    "Poco después llega una respuesta."

# game/story.rpy:789
translate spanish story_f73d0201:

    # s "{i}{u}Yes! What are we gonna do?{/i}{/u}"
    s "{i}{u}¡Venga! ¿Qué vamos a hacer?{/i}{/u}"

# game/story.rpy:790
translate spanish story_f406764b:

    # "I feel my heart speed up as soon as I see the words. I can tell this is coming from Meiji though."
    "Siento que el corazón se me acelera en cuanto leo sus palabras. Aunque sé perfectamente que es cosa de Meiji."

# game/story.rpy:791
translate spanish story_5816dccc:

    # "Guess he has a crush on her."
    "Supongo que está colado por ella."

# game/story.rpy:792
translate spanish story_49f9ad8b:

    # mc "What would Sayori like to do?"
    mc "¿Qué le gustaría hacer a Sayori?"

# game/story.rpy:793
translate spanish story_d10b2ccc:

    # "I wonder this aloud, mostly to myself."
    "Me lo pregunto en voz alta, casi para mí mismo."

# game/story.rpy:794
translate spanish story_21378476:

    # mc "I'd imagine she's the kind of gal who'd enjoy anything as long as others are happy. Does your city have arcade games and parks?"
    mc "Me la imagino como el tipo de chica que disfruta de cualquier cosa con tal de que los demás sean felices. ¿Hay salones recreativos o parques en tu ciudad?"

# game/story.rpy:795
translate spanish story_8aea9608:

    # mc "Oh, and good restaurants too."
    mc "Ah, y tal vez restaurantes."

# game/story.rpy:796
translate spanish story_b04ddae2:

    # cm "{i}I know a few places, yeah.{/i}"
    cm "{i}Conozco un par de sitios, sí.{/i}"

# game/story.rpy:797
translate spanish story_c8deb497:

    # mc "Perfect!"
    mc "¡Perfecto!"

# game/story.rpy:798
translate spanish story_c2a97043:

    # "I send Sayori a reply."
    "Le envío una respuesta a Sayori."

# game/story.rpy:799
translate spanish story_ef3dab74:

    # mc "{i}{u}We can go to the park, the arcade, maybe see a movie and get something nice to eat after if we have time{/i}{/u}."
    mc "{i}{u}Podemos ir al parque, a los recreativos, quizá ver una peli y comer algo rico luego si nos da tiempo{/i}{/u}."

# game/story.rpy:800
translate spanish story_de24caec:

    # cm "{i}You make it sound like a date!{/i}"
    cm "{i}¡Lo haces sonar como si fuera una cita!{/i}"

# game/story.rpy:801
translate spanish story_d15c0f0d:

    # "He sounds flustered now."
    "Ahora suena nervioso."

# game/story.rpy:802
translate spanish story_51509550:

    # cm "{i}I didn't agree to this! Stop it right now!{/i}"
    cm "{i}¡Yo no he accedido a esto! ¡Para ahora mismo!{/i}"

# game/story.rpy:803
translate spanish story_2dd6ab5b:

    # mc "Calm down. This is a good way to start making it up to Sayori for how distant you've become, as well as a great way to reconnect. Besides, I know you like her."
    mc "Cálmate. Es una buena manera de empezar a compensar a Sayori por lo distante que has estado, y también una forma genial de reconectar. Además, sé que te gusta."

# game/story.rpy:804
translate spanish story_02608975:

    # cm "{i}I-I don't like her like that!{/i}"
    cm "{i}¡N-No me gusta de esa manera!{/i}"

# game/story.rpy:805
translate spanish story_b62872c0:

    # "Now he sounds like Natsuki."
    "Ahora suena como Natsuki..."

# game/story.rpy:806
translate spanish story_79864f89:

    # mc "Dude, think about it for a second. You and I have a chance to rekindle your friendship with her. Isn't that worth a bit of embarrassment?"
    mc "Tío, piénsalo un segundo. Tú y yo tenemos la oportunidad de reavivar tu amistad con ella. ¿No merece la pena pasar un poco de vergüenza?"

# game/story.rpy:807
translate spanish story_95c3c840_6:

    # cm "..."
    cm "..."

# game/story.rpy:808
translate spanish story_3bc2e34a:

    # "While waiting for his response, Sayori texts back."
    "Mientras espero su respuesta, Sayori contesta al mensaje."

# game/story.rpy:809
translate spanish story_44e97c71:

    # s "{i}{u}Ooooh! Those all sound fun! What time?{/i}{/u}"
    s "{i}{u}¡Oooh! ¡Suena muy bien! ¿A qué hora?{/i}{/u}"

# game/story.rpy:810
translate spanish story_07da8f9c:

    # "I show Meiji the texts. I hear him sigh."
    "Le muestro los mensajes a Meiji. Le oigo suspirar."

# game/story.rpy:811
translate spanish story_e25bc04c:

    # cm "{i}Damn it...alright, you win. Just…don't do anything weird to her, okay?{/i}"
    cm "{i}Joder... Vale, tú ganas. Pero... no le hagas nada raro, ¿vale?{/i}"

# game/story.rpy:812
translate spanish story_88700a4e:

    # mc "Thanks, and don't worry, I won't. She's your crush, after all."
    mc "Gracias, y no te preocupes, no lo haré. Sé que es la chica que te gusta."

# game/story.rpy:813
translate spanish story_20f8d9a7:

    # "I shoot Sayori another text."
    "Le envío otro mensaje a Sayori."

# game/story.rpy:814
translate spanish story_305d2bda:

    # mc "{i}{u}I'll stop by your house at 10:30.{/i}{/u}"
    mc "{i}{u}Me pasaré por tu casa a las 10:30.{/i}{/u}"

# game/story.rpy:815
translate spanish story_4fa0b8d1:

    # s "{i}{u}See you then!{/i}{/u}"
    s "{i}{u}¡Vale, te veo luego!{/i}{/u}"

# game/story.rpy:816
translate spanish story_d93620bf:

    # "I smile, close the phone and begin gathering clothes for the day."
    "Sonrío, guardo el móvil y empiezo a preparar la ropa para hoy."

# game/story.rpy:818
translate spanish story_2ea8f99e:

    # cm "{i}You better know what you're doing.{/i}"
    cm "{i}Más te vale saber lo que haces.{/i}"

# game/story.rpy:819
translate spanish story_ca4b79fe:

    # "Yeah, I hope I do too..."
    "Sí, yo también lo espero..."

# game/story.rpy:825
translate spanish story_318e3a9f:

    # "I head downstairs and smell something cooking."
    "Bajo al piso de abajo y huelo que algo se está cocinando."

# game/story.rpy:827
translate spanish story_39a735e2:

    # "I see Meiji's mom at the stove cooking what smells like scrambled eggs."
    "Veo a la madre de Meiji en los fogones, cocinando lo que huelen a huevos revueltos."

# game/story.rpy:828
translate spanish story_701e662f:

    # "She sees me and smiles."
    "Me ve y sonríe."

# game/story.rpy:829
translate spanish story_005bd8c2:

    # mom 1bb "Good morning, sweetie. Did you sleep okay after last night?"
    mom 1bb "Buenos días, cariño. ¿Has dormido bien después de lo de anoche?"

# game/story.rpy:831
translate spanish story_78215334:

    # mc "Yeah, I did."
    mc "Sí."

# game/story.rpy:832
translate spanish story_5a830c20:

    # mom 5bb "Good, glad to hear it. Breakfast is almost ready."
    mom 5bb "Me alegro de oírlo. El desayuno está casi listo."

# game/story.rpy:834
translate spanish story_53d0a31d:

    # mc "Okay, I'm gonna take a shower and then I'll be right out."
    mc "Vale, me voy a dar una ducha y salgo enseguida."

# game/story.rpy:835
translate spanish story_657b22b7:

    # mom 1bd "Okay!"
    mom 1bd "¡Vale!"

# game/story.rpy:840
translate spanish story_adc220d9:

    # "It takes me a few minutes to shower."
    "Tardo unos minutos en ducharme."

# game/story.rpy:841
translate spanish story_dc6750db:

    # "Meiji says nothing the whole time."
    "Meiji no dice nada en todo el rato."

# game/story.rpy:842
translate spanish story_cd0b0c1c:

    # "It's strange taking a shower in a stranger's body. I close my eyes for the most part."
    "Es muy raro ducharse en el cuerpo de un desconocido. Cierro los ojos casi todo el tiempo."

# game/story.rpy:848
translate spanish story_f5d92ab0:

    # "When I head out into the kitchen again, I see Meiji's mom just beginning to set the table."
    "Cuando vuelvo a la cocina, veo a la madre de Meiji empezando a poner la mesa."

# game/story.rpy:849
translate spanish story_ab96340d:

    # "Breakfast for me is eggs and toast, same for her albeit with a nice hot cup of coffee."
    "Para desayunar tomo huevos y tostadas. Ella toma lo mismo, aunque acompañado de una buena taza de café."

# game/story.rpy:850
translate spanish story_fbecf12d:

    # mom 4bb "Oooh, you're dressed up today. Going out?"
    mom 4bb "Hala, hoy te has arreglado. ¿Vas a salir?"

# game/story.rpy:852
translate spanish story_aeb3e586:

    # mc "Yeah, Sayori and I made plans."
    mc "Sí, Sayori y yo hemos hecho planes."

# game/story.rpy:853
translate spanish story_f5080c36:

    # mom 4bb "Really??"
    mom 4bb "¿De verdad?"

# game/story.rpy:854
translate spanish story_6b2ce156:

    # mom 5bd "That's great! You haven't seen her in a while, have you?"
    mom 5bd "¡Qué bien! Hace tiempo que no la ves, ¿verdad?"

# game/story.rpy:856
translate spanish story_ac26f5c8:

    # mc "Yeah true. I kinda miss those times."
    mc "Sí, echo un poco de menos esos tiempos."

# game/story.rpy:857
translate spanish story_afa8b1ea:

    # mom 2ba "Anything special planned?"
    mom 2ba "¿Habéis planeado algo especial?"

# game/story.rpy:858
translate spanish story_6f5b25f6:

    # mc "Not really. I just thought of it this morning."
    mc "La verdad es que no. Se me ha ocurrido esta mañana."

# game/story.rpy:859
translate spanish story_678c967b:

    # mom 1bb "Well, why not take her to that café we all used to go to?"
    mom 1bb "Bueno, ¿por qué no la llevas a esa cafetería a la que solíamos ir?"

# game/story.rpy:861
translate spanish story_0380f15c:

    # mc "{b}What café is she talking about?{/b}"
    mc "{i}¿De qué cafetería habla?{/i}"

# game/story.rpy:862
translate spanish story_d1ffc36b:

    # cm "{i}Hmm, when we were kids our parents would sometimes take us to this one café and get us hot chocolate and cinnamon buns.{/i}"
    cm "{i}Mmm, cuando éramos niños, nuestros padres a veces nos llevaban a una cafetería y nos compraban chocolate caliente y rollitos de canela.{/i}"

# game/story.rpy:863
translate spanish story_5bbc3b82:

    # mc "{b}Oooh, sounds like a great idea!{/b}"
    mc "{i}Hala, ¡parece una idea genial!{/i}"

# game/story.rpy:864
translate spanish story_b742a82e:

    # mc "{b}And I just noticed, but we're talking to each other without me talking out loud.{/b}"
    mc "{i}Por cierto, me acabo de dar cuenta de que estamos hablando sin que yo diga nada en voz alta.{/i}"

# game/story.rpy:865
translate spanish story_1d064482:

    # mc "{b}Good to know we can do that.{/b}"
    mc "{i}Es bueno saber que podemos hacer eso.{/i}"

# game/story.rpy:866
translate spanish story_45f0ee4c:

    # cm "{i}Yeah, you won't look crazy.{/i}"
    cm "{i}Sí, así no parecerás un loco.{/i}"

# game/story.rpy:867
translate spanish story_608aaa59:

    # mc "{b}Heh, true.{/b}"
    mc "{i}Ya, es verdad.{/i}"

# game/story.rpy:868
translate spanish story_cf11ab2f:

    # mc "Hey, yeah! That's a good idea, Mom!"
    mc "¡Oye, sí! ¡Es una gran idea, mamá!"

# game/story.rpy:869
translate spanish story_2700e666:

    # mom 5bd "Hehe, your mom's no dummy, Meiji."
    mom 5bd "Je, je, tu madre no tiene un pelo de tonta, Meiji."

# game/story.rpy:870
translate spanish story_e70cf1e0:

    # mom 5bb "What else are you gonna do?"
    mom 5bb "¿Qué más vais a hacer?"

# game/story.rpy:872
translate spanish story_0d1969c7:

    # mc "Hmm...go wherever the mood strikes us, I guess."
    mc "Mmm... Iremos adonde nos apetezca, supongo."

# game/story.rpy:873
translate spanish story_75e0e48d:

    # mom 4ba "Well take it from a woman with experience, Meiji. Girls like the guy to plan out dates like this."
    mom 4ba "Haz caso a una mujer con experiencia, Meiji. A las chicas les gusta que el chico planee citas como esta."

# game/story.rpy:874
translate spanish story_bbe3b101:

    # mc "Mom! It's not that kind of thing!"
    mc "¡Mamá! ¡No es ese tipo de cosas!"

# game/story.rpy:875
translate spanish story_7256fe6e:

    # "Meiji and I both get embarrassed."
    "Meiji y yo nos morimos de vergüenza."

# game/story.rpy:876
translate spanish story_2c6fc481:

    # mom 2bc "Awww, how cute."
    mom 2bc "Ohhh, qué cuqui."

# game/story.rpy:877
translate spanish story_fee04d39:

    # mc "I...I give up..."
    mc "Me... Me rindo..."

# game/story.rpy:878
translate spanish story_7b84180b:

    # "I shrug in defeat as Meiji's mom laughs hard."
    "Me encojo de hombros, derrotado, mientras la madre de Meiji se ríe a carcajadas."

# game/story.rpy:879
translate spanish story_1b40f0f4:

    # mom 1bb "Relax, sweetie, I'm just teasing."
    mom 1bb "Relájate, cielo, solo te estoy tomando el pelo."

# game/story.rpy:881
translate spanish story_f43a7602:

    # mc "Nnng...fine fine."
    mc "Vale, vale."

# game/story.rpy:882
translate spanish story_b3d68aba:

    # mom 1bc "Now eat up. You've got a long day ahead of you."
    mom 1bc "Venga, come. Tienes un largo día por delante."

# game/story.rpy:883
translate spanish story_a1010c32:

    # mom 5bh "Try and be back before dark, okay?"
    mom 5bh "Intenta volver antes de que anochezca, ¿vale?"

# game/story.rpy:885
translate spanish story_d3bee692:

    # mc "Okay, I will."
    mc "Vale, lo haré."

# game/story.rpy:890
translate spanish story_d8085999:

    # "After breakfast I go to freshen up a bit more."
    "Después de desayunar, voy a asearme un poco más."

# game/story.rpy:891
translate spanish story_efb51d33:

    # "I brush my teeth next and comb my hair to make myself look presentable."
    "Luego me lavo los dientes y me peino para estar presentable."

# game/story.rpy:892
translate spanish story_dfcf4b9a:

    # mc "{b}I didn't realize your mom was that kind of mom.{/b}"
    mc "{i}No me había dado cuenta de que tu madre fuera ese tipo de madre.{/i}"

# game/story.rpy:893
translate spanish story_961e3a86:

    # cm "{i}Yeah, it's annoying at times. I'm sorry.{/i}"
    cm "{i}Sí, a veces es muy pesada. Lo siento.{/i}"

# game/story.rpy:894
translate spanish story_20d2feab:

    # mc "{b}It's fine. I can deal.{/b}"
    mc "{i}No pasa nada. Puedo soportarlo.{/i}"

# game/story.rpy:895
translate spanish story_fe91987b:

    # "Meiji makes a small grunt and goes back to being silent."
    "Meiji emite un pequeño gruñido y vuelve a quedarse callado."

# game/story.rpy:900
translate spanish story_370358ee:

    # "As I head to the front door to put on some shoes, Meiji speaks up."
    "Mientras me dirijo a la puerta principal para ponerme los zapatos, Meiji habla."

# game/story.rpy:901
translate spanish story_47db4027:

    # cm "{i}Hey, um, I'm sorry about earlier{/i}."
    cm "{i}Oye, siento lo de antes{/i}."

# game/story.rpy:902
translate spanish story_fcf97fcb:

    # mc "{b}No, don't be. I'm scared too, believe me. Also, thank you for believing me about this world being a game.{/b}"
    mc "{i}No, no lo sientas. Yo también estoy asustado, créeme. Además, gracias por creerme con lo de que este mundo es un videojuego.{/i}"

# game/story.rpy:903
translate spanish story_6c977a5e:

    # cm "{i}Well...I don't quite believe you.{/i}"
    cm "{i}Bueno... No te creo del todo.{/i}"

# game/story.rpy:904
translate spanish story_92e187d7:

    # mc "{b}That's understandable. But I promise that it's the truth. I wouldn't make something that silly up in this situation.{/b}"
    mc "{i}Es comprensible. Pero te prometo que es la verdad. No me inventaría una tontería así en una situación como esta.{/i}"

# game/story.rpy:905
translate spanish story_153e6531:

    # cm "{i}I guess not...but I'm still skeptical.{/i}"
    cm "{i}Supongo que no... Pero sigo siendo escéptico.{/i}"

# game/story.rpy:906
translate spanish story_e5a68a76:

    # mc "{b}I understand.{/b}"
    mc "{i}Ya, lo entiendo.{/b}"

# game/story.rpy:907
translate spanish story_c4f6fd8b:

    # mc "Mom, I'm heading out!"
    mc "¡Mamá, me voy!"

# game/story.rpy:908
translate spanish story_d25c5ab9:

    # mom "Oh wait!"
    mom "¡Ah, espera!"

# game/story.rpy:910
translate spanish story_2319688a:

    # "Meiji's mom comes running to the door and thrusts a few bills into my hand."
    "La madre de Meiji viene corriendo a la puerta y me pone unos billetes en la mano."

# game/story.rpy:911
translate spanish story_f537063c:

    # mc "Mom? What are you doing?"
    mc "¿Mamá? ¿Qué haces?"

# game/story.rpy:912
translate spanish story_8a7918fb:

    # mom 5bd "Giving my man some money for his date, dear."
    mom 5bd "Darle a mi hombrecito algo de dinero para su cita, cielo."

# game/story.rpy:914
translate spanish story_61603dd1:

    # mc "Ugh, it's not a date..."
    mc "Uf, que no es una cita..."

# game/story.rpy:915
translate spanish story_ff7e6a43:

    # mom 5bd "Awww, my sweet boy is blushing."
    mom 5bd "Halaaa, mi niño precioso se ha sonrojado."

# game/story.rpy:917
translate spanish story_61f6ea93:

    # cm "{i}Yeah...just take it. She's pretty persistent when it comes to this. She did the same thing with Aiko when she went out on dates.{/i}"
    cm "{i}Sí... Acéptalo y ya. Es muy insistente con estas cosas. Hizo lo mismo con Aiko cuando tenía citas.{/i}"

# game/story.rpy:918
translate spanish story_24d07c3b:

    # mc "{b}Really?{/b}"
    mc "{i}¿En serio?{/i}"

# game/story.rpy:919
translate spanish story_eddf3385:

    # cm "{i}Yeah. It's annoying I know, but bear with it.{/i}"
    cm "{i}Sí. Es un engorro, lo sé, pero ten paciencia.{/i}"

# game/story.rpy:920
translate spanish story_aea76108:

    # mc "{b}...Okay, fair enough.{/b}"
    mc "{i}Vale, me parece justo.{/i}"

# game/story.rpy:921
translate spanish story_eaf6d4e4:

    # "I put the money in Meiji's wallet."
    "Meto el dinero en la cartera de Meiji."

# game/story.rpy:922
translate spanish story_be62eb7b:

    # mc "Alright, thanks Mom. Well, I'm off."
    mc "Muy bien, gracias, mamá. Bueno, me voy."

# game/story.rpy:923
translate spanish story_8c69b0e9:

    # mom 4bb "Of course! Have fuuuun!"
    mom 4bb "¡Faltaría más! ¡Pásalo bien!"

# game/story.rpy:926
translate spanish story_a0c5bd55:

    # "She heads back inside."
    "Vuelve adentro."

# game/story.rpy:929
translate spanish story_1ff263b1:

    # "Sighing, I open the door and step outside."
    "Lanzo un suspiro, abro la puerta y salgo a la calle."

# game/story.rpy:936
translate spanish story_9c9eab67:

    # "A cold autumn breeze immediately washes over me and I inhale out of reflex."
    "Inmediatamente, una brisa fría de otoño me azota e inhalo por reflejo."

# game/story.rpy:937
translate spanish story_8d221767:

    # "Chilly!"
    "¡Qué rasca!"

# game/story.rpy:938
translate spanish story_ca388b2e:

    # "Shivering, I look back inside and notice a coat hanging on a hanger next to the door."
    "Temblando, miro hacia el interior de la casa y me fijo en un abrigo colgado en una percha junto a la puerta."

# game/story.rpy:939
translate spanish story_a769fa68:

    # mc "This yours?"
    mc "¿Este es tuyo?"

# game/story.rpy:940
translate spanish story_0004ab20:

    # cm "{i}Yep.{/i}"
    cm "{i}Sip.{/i}"

# game/story.rpy:941
translate spanish story_1adfc637:

    # "I put it on and walk out into the street."
    "Me lo pongo y salgo a la calle."

# game/story.rpy:942
translate spanish story_4b3d8a19:

    # "When we get onto the street, I turn and take a picture of Meiji's house from the angle it's seen as in the game."
    "Al salir a la calle, me giro y le saco una foto a la casa de Meiji desde el mismo ángulo en el que se ve en el juego."

# game/story.rpy:943
translate spanish story_bebc74d2:

    # mc "So, where's Sayori's place?"
    mc "Y bien, ¿dónde vive Sayori?"

# game/story.rpy:944
translate spanish story_3b45d186:

    # cm "{i}It's not too far away. I'll lead you to it.{/i}"
    cm "{i}No está muy lejos. Yo te guío.{/i}"

# game/story.rpy:949
translate spanish story_22850bbf:

    # "I look up and see the scene from the very first moments of the game."
    "Levanto la mirada y me encuentro con la escena de los primeros instantes del juego."

# game/story.rpy:950
translate spanish story_4cf672ad:

    # "Not surprising, really."
    "Tampoco es que me sorprenda, la verdad."

# game/story.rpy:951
translate spanish story_dd34a892:

    # "Wait...were those lights always there?"
    "Un momento... ¿Esas luces siempre han estado ahí?"

# game/story.rpy:952
translate spanish story_7517cfd2:

    # "Eh, not important right now."
    "En fin, ahora mismo eso no importa."

# game/story.rpy:953
translate spanish story_0186d578:

    # "I take another picture then head to the house."
    "Saco otra foto y me dirijo hacia la casa."

# game/story.rpy:954
translate spanish story_5d609ffa:

    # "Meiji leads me a few houses away."
    "Meiji me guía a unas pocas casas de allí."

# game/story.rpy:959
translate spanish story_50acc1c5:

    # mc "Is it okay if I just walk in?"
    mc "¿Seguro que puedo entrar sin más?"

# game/story.rpy:960
translate spanish story_d9a16475:

    # cm "{i}Yeah, I did it all the time. Her family almost never keeps her door locked.{/i}"
    cm "{i}Sí, yo lo hacía todo el tiempo. Su familia casi nunca echa la llave.{/i}"

# game/story.rpy:961
translate spanish story_6651ab87:

    # mc "Alright."
    mc "Vale."

# game/story.rpy:969
translate spanish story_44dc75fd:

    # "I throw Sayori's front door open."
    "Abro de par en par la puerta principal."

# game/story.rpy:970
translate spanish story_d52aac64:

    # mc "Sayori! I'm here!"
    mc "¡Sayori! ¡Ya estoy aquí!"

# game/story.rpy:971
translate spanish story_4042ddf3:

    # "I hear a shuffle from inside."
    "Oigo unos pasos acercándose desde dentro."

# game/story.rpy:972
translate spanish story_5d7d3574:

    # u "Is that you, Meiji? Come on in!"
    u "¿Eres tú, Meiji? ¡Pasa, pasa!"

# game/story.rpy:973
translate spanish story_52819dbf:

    # mc "Oh, sure thing!"
    mc "¡Ah, claro!"

# game/story.rpy:978
translate spanish story_dcfb89f2:

    # "I walk inside."
    "Entro."

# game/story.rpy:979
translate spanish story_06f35f98:

    # mc "Wow...nice house."
    mc "Hala... Qué casa más bonita."

# game/story.rpy:980
translate spanish story_73063811:

    # cm "{i}It really is.{/i}"
    cm "{i}La verdad es que sí.{/i}"

# game/story.rpy:981
translate spanish story_53e71de2:

    # "The door in the corner opens and someone walks through."
    "La puerta de la esquina se abre y alguien sale por ella."

# game/story.rpy:983
translate spanish story_6512474b:

    # u "Meiji-kun! It's nice to see you! It's been a while!"
    u "¡Meiji! ¡Me alegro de verte! ¡Cuánto tiempo!"

# game/story.rpy:985
translate spanish story_7add58eb:

    # "...Whoa..."
    "Hostia..."

# game/story.rpy:986
translate spanish story_d1411dfd:

    # "Does Sayori have an older sister?"
    "¿Sayori tiene una hermana mayor?"

# game/story.rpy:987
translate spanish story_0b735e89:

    # cm "{i}This is Sayori's mom, Fujioka Sayako. I normally call her Fujioka-san.{/i}"
    cm "{i}Es la madre de Sayori, Sayako Fujioka. Yo suelo llamarla señora Fujioka.{/i}"

# game/story.rpy:988
translate spanish story_4ada9b78:

    # "Her mom? No way! She looks way too young!"
    "¿Su madre? ¡No fastidies! ¡Parece demasiado joven!"

# game/story.rpy:989
translate spanish story_f6a4259c:

    # mc "Ah, um, yeah. Sorry for not stopping by more often."
    mc "Ah, pues sí. Siento no haberme pasado más a menudo."

# game/story.rpy:990
translate spanish story_3ec3f926:

    # sm 2 "What are you doing here?"
    sm 2 "¿Qué te trae por aquí?"

# game/story.rpy:992
translate spanish story_bd9bd67c:

    # mc "Heh, well I invited Sayori to spend the day with me. I hope that's alright. It was a spur of the moment thing."
    mc "Je, je, bueno, he invitado a Sayori a pasar el día conmigo. Espero que no le importe. Ha sido un arrebato."

# game/story.rpy:993
translate spanish story_b67cc7dc:

    # sm 4 "Oh my, that's adorable. She's still in her room."
    sm 4 "Ay, por favor, qué adorable. Aún está en su cuarto."

# game/story.rpy:994
translate spanish story_d131e298:

    # sm 6 "I don't mind you two going out as long as you bring her back at a good time."
    sm 6 "No me importa que salgáis, siempre y cuando la traigas de vuelta a una hora prudente."

# game/story.rpy:996
translate spanish story_d9bdf35c:

    # "My cheeks flush."
    "Me ruborizo."

# game/story.rpy:997
translate spanish story_db9b4607:

    # mc "Of course I will."
    mc "Por supuesto."

# game/story.rpy:999
translate spanish story_89c5b2ea:

    # "Sayori's mother makes her way to the stairs."
    "La madre de Sayori se acerca a las escaleras."

# game/story.rpy:1000
translate spanish story_1b846cf4:

    # sm 5 "Sayori! Meiji-kun is here!"
    sm 5 "¡Sayori! ¡Meiji está aquí!"

# game/story.rpy:1001
translate spanish story_8ff0782c:

    # s "Coming!"
    s "¡Ya voy!"

# game/story.rpy:1003
translate spanish story_77a9a126:

    # sm "She'll be down soon, dear."
    sm "Enseguida baja, cielo."

# game/story.rpy:1005
translate spanish story_10bef510:

    # mc "No rush."
    mc "Sin prisas."

# game/story.rpy:1006
translate spanish story_377e68d6:

    # sm 4 "Now, if you'll excuse me, I've got some cooking to do."
    sm 4 "Ahora, si me disculpas, tengo comida que preparar."

# game/story.rpy:1007
translate spanish story_87add3f5:

    # mc "Not a problem."
    mc "Faltaría más."

# game/story.rpy:1010
translate spanish story_d00901d5:

    # "Sayori's mom heads back into the kitchen. Soon I hear a door close upstairs."
    "La madre de Sayori vuelve a la cocina. Al poco rato, oigo cerrarse una puerta en el piso de arriba."

# game/story.rpy:1011
translate spanish story_741a0ea2:

    # "Judging from the jump in heartbeat I feel, I have a pretty good idea who this could be."
    "A juzgar por el vuelco que me ha dado el corazón, me hago una idea bastante clara de quién puede ser."

# game/story.rpy:1012
translate spanish story_aa07dbe4:

    # "Someone comes flying down the stairs."
    "Alguien baja volando las escaleras."

# game/story.rpy:1014
translate spanish story_4fb00ed3:

    # "Despite her different hair color, that red bow can only mean that the teen in front of me is Sayori."
    "A pesar de que su color de pelo es distinto, ese lazo rojo solo puede significar que la adolescente que tengo delante es Sayori."

# game/story.rpy:1015
translate spanish story_9782f0d0:

    # mc "Hey, Sayori. It's been a while."
    mc "Hola, Sayori. Cuánto tiempo."

# game/story.rpy:1016
translate spanish story_eab67f1c:

    # "I utilize the nervousness I feel from Meiji into my own performance. I smile sheepishly."
    "Aprovecho el nerviosismo que percibo de Meiji para mi propia actuación. Sonrío con timidez."

# game/story.rpy:1017
translate spanish story_b9c71619:

    # mc "I hope I didn't wake you. I know how you like to sleep in."
    mc "Espero no haberte despertado. Sé lo mucho que te gusta quedarte pegada a las sábanas."

# game/story.rpy:1018
translate spanish story_57db8685:

    # "From the kitchen I hear Sayori's mom chuckle."
    "Desde la cocina oigo a la madre de Sayori soltar una risita."

# game/story.rpy:1019
translate spanish story_7660412d:

    # sm "He's got you pegged, sweetie!"
    sm "¡Te tiene calada, cielo!"

# game/story.rpy:1020
translate spanish story_787cf0d3:

    # s 4hj "Moooom! Meanie..."
    s 4hj "¡Mamááá!"
    s "Malo..."

# game/story.rpy:1022
translate spanish story_4ef038e9:

    # "Sayori directs that last word at me."
    "Sayori me dirige esa última palabra a mí."

# game/story.rpy:1023
translate spanish story_ff388ea6:

    # "You know, I bet Meiji's mom and Sayori's mom are best friends from how similar they are."
    "La verdad, me apuesto lo que sea a que la madre de Meiji y la de Sayori son íntimas amigas por lo mucho que se parecen."

# game/story.rpy:1024
translate spanish story_364a1910:

    # mc "I'm kidding, I'm kidding."
    mc "Es broma, es broma."

# game/story.rpy:1025
translate spanish story_9b468111:

    # "I reach over to ruffle her hair."
    "Extiendo el brazo para alborotarle el pelo."

# game/story.rpy:1027
translate spanish story_6d7e476d:

    # "She seems to relax."
    "Parece que se relaja."

# game/story.rpy:1028
translate spanish story_fbb6171b:

    # mc "But seriously, I hope I didn't wake you up from a nice dream."
    mc "Pero en serio, espero no haberte despertado de un buen sueño."

# game/story.rpy:1030
translate spanish story_12555c4c:

    # s "Nope! I was already awake!"
    s "¡Qué va! ¡Ya estaba despierta!"

# game/story.rpy:1032
translate spanish story_3b1ce6d1:

    # cm "{i}Same old Sayori...{/i}"
    cm "{i}La Sayori de siempre...{/i}"

# game/story.rpy:1034
translate spanish story_b8046419:

    # s "Lemme just grab my things, and then we can go."
    s "Déjame coger mis cosas y nos vamos."

# game/story.rpy:1037
translate spanish story_a1487f3b:

    # "As Sayori gets her belongings, I decide to tease everyone at once. I call out to the kitchen."
    "Mientras ella recoge sus cosas, decido pinchar a todo el mundo a la vez. Llamo a la cocina."

# game/story.rpy:1038
translate spanish story_7f1ae952:

    # mc "Thank you for letting me borrow your daughter. I'll have her home before dinner."
    mc "Gracias por dejarme tomar prestada a su hija. La traeré de vuelta antes de cenar."

# game/story.rpy:1039
translate spanish story_bd1e876d:

    # "Fujioka-san comes out."
    "La señora Fujioka se asoma."

# game/story.rpy:1041
translate spanish story_d8093060:

    # sm "Ara, ara! It's like you're taking my daughter out on a date."
    sm "¡Hala! Parece que vayas a llevarte a mi hija a una cita."

# game/story.rpy:1044
translate spanish story_446e62d0:

    # s "E-Eh!?"
    s "¡¿E-Eh?!"

# game/story.rpy:1048
translate spanish story_4aa9945a:

    # "Sayori's mom leaves just as our faces both flush red."
    "La madre de Sayori se marcha justo cuando ambos nos ponemos rojos como tomates."
